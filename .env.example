# Public site URL (used for absolute metadata URLs)
NEXT_PUBLIC_SITE_URL=https://www.jandf-auto.com

# AWS region for DynamoDB / S3 / Cognito clients
# This Amplify app lives in us-east-2 — must match the region of every backing resource.
AWS_REGION=us-east-2

# DynamoDB tables (defaults shown)
JFAUTO_CARS_TABLE=jfauto-cars
JFAUTO_LEADS_TABLE=jfauto-leads
JFAUTO_SETTINGS_TABLE=jfauto-settings

# S3 bucket holding car imagery (must be publicly readable, or fronted by CloudFront)
# NOTE: bucket names cannot contain underscores
JFAUTO_S3_BUCKET=your-jfauto-images-bucket
# Optional: explicit public base URL (e.g. CloudFront domain). If unset, the
# app derives https://{bucket}.s3.{region}.amazonaws.com.
JFAUTO_S3_PUBLIC_BASE_URL=

# Cognito User Pool with `custom:role` attribute (admin | staff | readonly)
COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Single allowed admin email. If set, every other email is rejected at login
# AND every session check — defense in depth. Leave unset to allow any Cognito user.
ADMIN_ALLOWED_EMAIL=
