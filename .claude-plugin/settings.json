{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(sudo:*)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(git push --force:*)"
    ]
  },
  "sandbox": {
    "failIfUnavailable": false,
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.local",
        "secrets/**"
      ],
      "allowRead": [
        ".env.example"
      ]
    }
  }
}
